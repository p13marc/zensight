{
  // Zenoh connection settings
  zenoh: {
    mode: "peer",                    // "client", "peer", or "router"
    // connect: ["tcp/localhost:7447"], // Router endpoints (if client mode)
    serialization: "json",           // "json" or "cbor"
  },

  // On-demand debug reports (@/report) — opt-in. When enabled, an operator can
  // download a redacted tar.zst bundle (config + health + counters) from the GUI.
  report: {
    enabled: false,
    max_bytes: 67108864,   // 64 MiB cap on the (uncompressed) bundle
    cooldown_secs: 30,
    ttl_secs: 600,
    chunk_size: 524288,
  },

  // systemd sensor settings
  systemd: {
    // Key expression prefix
    key_prefix: "zensight/systemd",

    // How often to read the systemd Manager (seconds)
    poll_interval_secs: 15,

    // Telemetry source id; defaults to the local hostname when omitted.
    // source: "gw01",

    // Per-unit telemetry watchlist (#273): globs of units to stream
    // unit/<name>/* for. Empty = none (only aggregates). Capped by watch_max.
    watch_units: [],           // e.g. ["sshd.service", "nginx*.service", "*.timer"]
    watch_max: 50,
    ip_io_accounting: false,   // include ip/io bytes when the unit enables accounting

    events_capacity: 256,      // control-plane event ring size (#275, @/query/events)

    // Built-in threshold alerts (#276) → @/alerts/*.
    alerts: {
      enabled: true,
      for_secs: 15,            // debounce before a firing alert publishes
      unit_failed: true,       // watched unit ActiveState=failed (see logs-sensor dedup)
      system_degraded: true,   // SystemState=degraded / NFailedUnits>0
      restart_storm_threshold: 3,
      restart_storm_window_secs: 300,
      unit_mem_ceiling_bytes: 0,   // 0 disables the unit-mem rule
      timer_overdue_grace_secs: 300,
    },

    // cgroup-tree query (#280) — served on demand at @/query/cgroups[?path=<rel>];
    // never streamed. Unprivileged /sys/fs/cgroup v2 walk, depth/breadth capped.
    cgroup: { root: "system.slice", max_depth: 6, max_children: 64, max_pids: 32 },

    // Embedded sentinel (#277) — declarative expectations → @/alerts/*,
    // hot-swappable via @/commands/expectations. Omit to disable.
    // expectations: {
    //   eval_interval_secs: 10,
    //   for_secs: 15,
    //   services_active: [{ unit: "sshd.service" }],
    //   targets_active: [{ target: "multi-user.target" }],
    //   timers: [{ timer: "logrotate.timer", within_secs: 90000 }],
    //   restart_rates: [{ unit: "nginx.service", max: 5, window_secs: 600 }],
    //   forbid_failed: true,
    // },

    // Gated service control (#283) — DEFAULT OFF. Destructive + privileged; the
    // sensor is strictly read-only unless this is explicitly enabled with an
    // allowlist. Authorization is enforced by systemd/polkit (run as root, or add
    // a scoped polkit rule granting org.freedesktop.systemd1.manage-units for the
    // allowlisted units). @/commands/action {verb,unit} → @/status/action.
    // actions: {
    //   enabled: false,
    //   allow_units: ["nginx.service", "app-*.service"],
    //   job_timeout_secs: 30,
    // },

    collect: {
      // Enumerate units (ListUnits) for units/{total,active,failed,loaded,inactive}.
      // Turn off to only collect the cheap manager/* scalars + boot timings.
      list_units: true,
      // Boot-performance phase durations (boot/*_usec), like systemd-analyze.
      boot: true,
      // Mount/automount state aggregates mounts/{total,mounted,failed} (#279).
      mounts: false,
      // Journal store health journal/{disk_usage_bytes,disk_available_bytes} (#279).
      journal: false,
    },
  },

  // Logging
  logging: {
    level: "info",
  },
}
