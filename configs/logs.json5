{
  // Logs sensor configured for local systemd-journald ingestion (used by
  // `just run`). For network syslog (UDP/TCP/Unix listeners) see syslog.json5.
  zenoh: {
    mode: "peer",
  },

  syslog: {
    key_prefix: "zensight/syslog",

    // No network listeners — this instance reads the local journal only.
    listeners: [],

    // systemd-journald source (#57). Reads the local journal directly via
    // libsystemd (no `journalctl` subprocess).
    journald: {
      enabled: true,

      // Which journal to read. "system" = full host journal and the kernel;
      // needs journal-read access (add your user to the `systemd-journal`
      // group, or run as a system service). Use "user" for the per-user journal.
      scope: "system",

      // Only entries from launch onward. Use "cursor" for gap-free resume
      // across restarts (persists a cursor file), or "since" with `since`.
      start_from: "tail",

      // detect_events defaults to true: coredump / unit-failed / OOM journal
      // events (matched by MESSAGE_ID) are raised as alerts on @/alerts.

      // Robustness under storms / rotation (#62). The reader feeds a bounded
      // channel; pick what happens when it fills:
      //   "drop_newest" (default) — shed + count incoming entries (bounded mem)
      //   "block"                 — backpressure the journal read (no loss, may lag)
      overflow: "drop_newest",
      // Optional global rate limit (entries/sec). Beyond it, keep 1-in-N and
      // count the rest as sampled-out so one screaming unit can't drown the bus.
      // max_eps: 5000,
      sample_ratio: 100,
      // Raise an ErrorReport once loss exceeds this fraction over a window (1%).
      drop_alert_ratio: 0.01,
    },

    // Derived rollup telemetry (#63): per-severity + per-unit (top-N) log rates,
    // error/warning rollups, units-in-failure, and journald throughput — emitted
    // every `derived_interval_secs` under zensight/syslog/<host>/logs/*.
    derived: true,
    derived_interval_secs: 10,
    top_units: 10, // distinct per-unit series; the rest fold into `other`
  },

  logging: { level: "info" },
}
