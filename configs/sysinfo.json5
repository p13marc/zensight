{
  // Zenoh connection settings
  zenoh: {
    mode: "peer",                    // "client", "peer", or "router"
    // connect: ["tcp/localhost:7447"], // Router endpoints (if client mode)
  },

  // On-demand debug reports (@/report) — opt-in. When enabled, an operator can
  // download a redacted tar.zst bundle (config + health + counters) from the
  // GUI. Generation is bounded and rate-limited; secrets are redacted.
  report: {
    enabled: false,        // set true to allow report downloads from this sensor
    max_bytes: 67108864,   // 64 MiB cap on the (uncompressed) bundle
    cooldown_secs: 30,     // min gap between generations
    ttl_secs: 600,         // how long a generated bundle stays downloadable
    chunk_size: 524288,    // 512 KiB transfer chunk (clamped 256 KiB–1 MiB)
  },

  // Tier-2 directory snapshots (@/snapshot + @/store + @/tree) — opt-in. When
  // enabled, an operator can download a whole allowlisted directory tree from the
  // GUI (content-addressed + dedup'd + restart-resumable). The operator picks a
  // directory by its logical `name`, never an arbitrary path — `dirs` is the
  // authorization boundary. A netring sensor would point one of these at its pcap
  // capture output dir; here it ships disabled with no directories.
  snapshot: {
    enabled: false,        // set true to allow directory downloads from this sensor
    dirs: [
      // { name: "etc", path: "/etc" },              // example: a /etc snapshot
      // { name: "pcaps", path: "/var/lib/netring" }, // example: captured pcaps
    ],
    max_bytes: 268435456,  // 256 MiB cap on the (uncompressed) snapshot
    max_files: 50000,      // cap on the number of files in a snapshot
    cooldown_secs: 30,     // min gap between builds
    ttl_secs: 600,         // how long a built snapshot stays downloadable
    chunk_size: 262144,    // 256 KiB average (FastCDC content-defined chunking)
  },

  // System information collection settings
  sysinfo: {
    // Key expression prefix
    key_prefix: "zensight/sysinfo",

    // Hostname for key expressions
    // Use "auto" to detect automatically, or specify a custom name
    hostname: "auto",

    // Poll interval in seconds
    poll_interval_secs: 5,

    // Which metrics to collect
    collect: {
      // CPU usage (global and per-core)
      cpu: true,

      // Memory usage (RAM and swap)
      memory: true,

      // Disk usage (per mount point)
      disk: true,

      // Network statistics (per interface)
      network: true,

      // System info (uptime, load averages)
      system: true,

      // Top processes by CPU/memory (can be resource-intensive)
      processes: false,

      // Number of top processes to report (if processes: true)
      top_processes: 10,
    },

    // Network interface filtering
    network: {
      // Only include these interfaces (empty = include all)
      include: [],

      // Exclude these interfaces
      exclude: [],

      // Exclude loopback interface (lo)
      exclude_loopback: true,

      // Exclude virtual interfaces (docker*, veth*, br-*, virbr*, vnet*)
      exclude_virtual: false,
    },

    // Disk mount point filtering
    disk: {
      // Only include these mount points (empty = include all)
      include: [],

      // Exclude these mount points
      exclude: [],

      // Exclude pseudo filesystems (tmpfs, sysfs, proc, etc.)
      exclude_pseudo: true,
    },

    // Threshold-based alerting. Each poll tick the already-collected saturation
    // data is graded against these thresholds and firing/resolved alerts are
    // published on zensight/sysinfo/@/alerts/* (same channel as the other
    // sensors; the GUI picks them up with no extra wiring). All values below are
    // the built-in defaults — the whole `alerts` block is optional.
    alerts: {
      // Master switch for all sysinfo alerting.
      enabled: true,

      // "Must be violated continuously for N seconds" debounce before a firing
      // alert is published (0 = publish on first violation).
      for_secs: 0,

      // New OOM kills since the last poll (memory/oom_kills_total delta > 0).
      // Always Critical.
      oom: { enabled: true },

      // PSI some/avg10 per resource: Warning at *_warn, Critical at *_critical.
      // Needs collect.pressure (on by default). Memory is graded harder.
      pressure: {
        enabled: true,
        cpu_warn: 40, cpu_critical: 70,
        memory_warn: 10, memory_critical: 30,
        io_warn: 40, io_critical: 70,
      },

      // Disk space hi-watermark per mount (Warning/Critical %). Needs collect.disk.
      disk: { enabled: true, warn_percent: 90, critical_percent: 95 },

      // Inode hi-watermark per mount. Needs collect.fd_inode (on by default).
      inode: { enabled: true, warn_percent: 90, critical_percent: 95 },

      // File-descriptor table occupancy (fs.file-nr / fs.file-max). Warning only.
      fd: { enabled: true, warn_percent: 80 },

      // Thermal: Critical when temp >= fraction * critical trip point.
      // OFF by default — requires collect.temperatures: true (which provides the
      // critical trip points). Enable both together.
      thermal: { enabled: false, fraction: 0.9 },

      // Swap thrash: Warning when (pswpin + pswpout) exceeds the page rate.
      // Needs collect.vmstat (on by default). 1000 pages/s ~= 4 MiB/s.
      swap: { enabled: true, warn_pages_per_sec: 1000 },
    },
  },

  // Logging
  logging: {
    level: "info",                   // "trace", "debug", "info", "warn", "error"
  },
}
