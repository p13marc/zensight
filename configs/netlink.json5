{
  // Zenoh connection settings
  zenoh: {
    mode: "peer",
  },

  // On-demand debug reports (@/report) — opt-in. When enabled, an operator can
  // download a redacted tar.zst bundle (config + health + counters) from the
  // GUI. Generation is bounded and rate-limited; secrets are redacted.
  report: {
    enabled: false,        // set true to allow report downloads from this sensor
    max_bytes: 67108864,   // 64 MiB cap on the (uncompressed) bundle
    cooldown_secs: 30,     // min gap between generations
    ttl_secs: 600,         // how long a generated bundle stays downloadable
    chunk_size: 524288,    // 512 KiB transfer chunk (clamped 256 KiB–1 MiB)
    // redact_extra: ["my_custom_secret_field"],  // extra field-name patterns
  },

  // Netlink sensor settings
  netlink: {
    key_prefix: "zensight/netlink",
    hostname: "auto",
    poll_interval_secs: 2,
    collect: {
      interfaces: true,
      sockets: true,
      neighbors: true,   // ARP/NDP neighbor state summary
      routes: true,      // routing-table summary
      diagnostics: true, // bottleneck score + issue counts
      events: true,      // real-time RTNETLINK event stream (#8)
      ethtool: true,     // link speed/duplex, ring sizes, drops (#9)
      addresses: true,   // IP address inventory (#10)
      tc: true,          // TC/QoS qdisc drops/overlimits/backlog (#12) — drives the TC panel
      xfrm: true,        // IPsec/xfrm SA + policy health (#13); empty without IPsec
      // The two below need CAP_NET_ADMIN — enable on a firewall / NAT gateway:
      nftables: false,   // nftables table/chain/rule counters (#14)
      conntrack: false,  // conntrack table summary
      // Opt-in eBPF module (#114) — connect-latency gauges + retransmit
      // attribution (@/query/retransmits) + tcplife records (@/query/connections).
      // Needs a binary built with `--features ebpf` (nightly + bpf-linker) AND
      // CAP_BPF/CAP_NET_ADMIN. No-op otherwise. Off by default.
      ebpf: false,
    },
    // Opt-in eBPF module tuning (#114). Only used when collect.ebpf is set.
    ebpf: {
      conn_ring_capacity: 256, // recent-connections ring (@/query/connections)
      retransmit_top_k: 20,    // top peers returned by @/query/retransmits
    },
    interfaces: {
      exclude_loopback: false,
      exclude_virtual: false,
    },

    // Pillar B — declared expectations for THIS host (sentinel). The sensor
    // evaluates these and emits alerts (zensight/netlink/@/alerts/*) on
    // deviation, auto-resolving when satisfied again. Expectations added live
    // from the GUI (Expectations view) are merged with these.
    expectations: {
      eval_interval_secs: 3,
      default_for_secs: 3,         // debounce: violated continuously for N s
      sockets: [
        // Security baseline: nothing should be listening on telnet. Safe on a
        // clean host (won't false-fire), demonstrates a forbid_listen rule.
        { name: "no-telnet", forbid_listen: 23, severity: "critical" },

        // Demo: a service that should be listening but (intentionally) isn't —
        // this FIRES on `just run` so you can see the alert pipeline end to end.
        // Change the port to a real service (e.g. 22 for sshd) for a live check.
        { name: "demo-expected-service", listen: 65000, severity: "warning" },
      ],
      // links: [
      //   { iface: "eth0", up: true, severity: "critical" },
      // ],
    },
  },

  logging: { level: "info" },
}
