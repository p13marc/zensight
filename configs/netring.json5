{
  // Zenoh connection settings
  zenoh: { mode: "peer" },

  // On-demand debug reports (@/report) — opt-in. When enabled, an operator can
  // download a redacted tar.zst bundle (config + health + counters) from the
  // GUI. Generation is bounded and rate-limited; secrets are redacted.
  report: {
    enabled: false,        // set true to allow report downloads from this sensor
    max_bytes: 67108864,   // 64 MiB cap on the (uncompressed) bundle
    cooldown_secs: 30,     // min gap between generations
    ttl_secs: 600,         // how long a generated bundle stays downloadable
    chunk_size: 524288,    // 512 KiB transfer chunk (clamped 256 KiB–1 MiB)
  },

  // Tier-2 directory snapshots (@/snapshot + @/store + @/tree) — opt-in. The
  // natural fit for netring: expose a captured-pcap directory for forensic pull
  // (content-addressed, dedup'd, restart-resumable). The operator picks a dir by
  // its logical `name`, never a raw path — `dirs` is the authorization boundary.
  snapshot: {
    enabled: false,        // set true to allow directory downloads from this sensor
    dirs: [
      // { name: "pcaps", path: "/var/lib/netring/pcaps" },  // captured pcap set
    ],
    max_bytes: 268435456,  // 256 MiB cap on the (uncompressed) snapshot
    max_files: 50000,      // cap on the number of files in a snapshot
    cooldown_secs: 30,     // min gap between builds
    ttl_secs: 600,         // how long a built snapshot stays downloadable
    chunk_size: 262144,    // 256 KiB average (FastCDC content-defined chunking)
  },

  // Netring sensor settings
  netring: {
    key_prefix: "zensight/netring",
    sensor_id: "auto",

    // Live capture interfaces (needs CAP_NET_RAW). Leave empty and set `pcap`
    // below to replay an offline capture instead (no privileges required).
    interfaces: ["eth0"],
    // pcap: "/path/to/capture.pcap",

    collect: {
      bandwidth: true,   // per-application bytes/sec
      flows: true,       // flow lifecycle aggregates
      tcp_resets: true,  // TCP reset + connection-refused counters
      // TCP initiator inference (netring 0.28, #122): recover the true SYN
      // sender so flow/matrix/talkers are labelled client -> server regardless
      // of capture endpoint order. No-op cost when off. Default ON, TCP-only.
      infer_initiator: true,
      // L7 RED analytics (cleartext only). Enabled here so the GUI's DNS/HTTP
      // detail tabs (@/query/dns, @/query/http) work out of the box; without
      // these the sensor declares no DNS/HTTP queryable and a fetch returns
      // "No netring sensor responded".
      dns: true,         // DNS queries/rcodes/RTT + top SLDs (UDP/53)
      http: true,        // HTTP requests/status/latency + top hosts (TCP/80,8080)
      // L7 protocol visibility (netring 0.27, opt-in). Detail served on
      // @/query/quic and @/query/ssh; aggregate counts stream.
      quic: false,       // passive QUIC Initial SNI/ALPN/version (UDP/443)
      ssh: false,        // SSH banner + KEXINIT HASSH fingerprints (TCP/22)
      // Flag cleartext SNMP v1/v2c community strings as anomalies. Needs the
      // sensor built with `--features snmp` (pulls the SNMP parser).
      snmp_cleartext: false,
      // Canonical IPFIX flow export (netring 0.28, #223). No-op unless built
      // with `--features ipfix`. Serves IANA-IE-keyed flow records on
      // @/query/ipfix (per-direction deltas IE 1/2, totals IE 85/86, precise
      // flowEndReason IE 136, Community ID) for SIEM / flow-collector consumers.
      ipfix: false,
      // Passive asset inventory (netring 0.27): discover hosts on the wire from
      // ARP / NDP / LLDP. Streams an `assets/discovered` count; the per-asset
      // detail (MAC / IP / hostname / platform / seen-via) is served on demand
      // via `@/query/assets`. Needs capture (CAP_NET_RAW).
      assets: true,
      // Also feed the inventory from CDP. Separate flag because CDP forces the
      // kernel prefilter to capture-all (it can't be expressed as a BPF term).
      asset_cdp: false,
    },
    bandwidth_period_secs: 5,

    // Pillar A — network anomaly detectors.
    anomalies: {
      port_scan: true,   // TRW port-scan detection -> alerts

      // Lateral movement (#123, ATT&CK T1021/T1558): SMB admin-share / IPC$
      // service-pipe access, RDP connection requests, Kerberos kerberoast /
      // weak-etype / brute-force. Build with `--features lateral` (pulls the
      // SMB/RDP/Kerberos parsers); a no-op when built without it.
      lateral_movement: false,

      // Data exfiltration (#123, ATT&CK T1048): flags a flow whose outbound
      // bytes exceed its per-source learned baseline by `exfil_sigma` stddevs
      // (and the `exfil_min_bytes` floor). Needs `collect.flows`.
      data_exfil: false,
      exfil_sigma: 4.0,
      exfil_min_bytes: 10485760, // 10 MiB outbound-byte floor
    },

    // Threat-intel detection (netring 0.27). Hits become alerts on @/alerts via
    // the same path as the detectors above.
    threat: {
      // Passive flow-risk scoring: obsolete TLS, cleartext HTTP credentials.
      flow_risk: true,
      // Indicator-of-compromise matching (bad IPs / domains / JA3 / JA4).
      ioc: {
        ips: [],          // e.g. ["203.0.113.6"] — matched against flow src/dst
        domains: [],      // e.g. ["evil.example"] — DNS qname / TLS SNI / HTTP Host
        ja4: [],          // bad JA4 client fingerprints
        ja3: [],          // bad JA3 client fingerprints
        files: [],        // newline IOC feeds (IP or domain per line, # comments)
      },
      // Sigma rule evaluation (build with `--features sigma`).
      sigma: { enabled: false, dir: null },
    },

    // Capture-overload detection (netring 0.27). Watches the windowed capture
    // drop-rate and raises/clears a `capture-overload` SensorHealth alert on the
    // debounced Normal<->Emergency transition. Needs `collect.capture_stats`.
    overload: {
      enabled: true,
      enter_drop_rate: 0.05,    // enter Emergency at 5% windowed drop rate
      recover_drop_rate: 0.01,  // recover below 1% ...
      recover_windows: 3,       // ... sustained for 3 calm windows (hysteresis)
      // Active load-shedding (netring 0.28, #224). Off by default: when on, the
      // sensor *deliberately* sheds new flows while in Emergency — honest,
      // counted drops (capture/<source>/shed/*) and a `shedding` label on the
      // capture-overload alert, instead of opaque kernel loss. Already-tracked
      // flows keep flowing (elephant-friendly).
      shed: {
        enabled: false,
        policy: "new_flows",    // "new_flows" (drop all new) | "sample"
        sample_rate: 0.5,       // for "sample": fraction of new flows to keep
      },
    },
  },

  logging: { level: "info" },
}
