{
  // Zenoh connection settings
  zenoh: { mode: "peer" },

  // Netring sensor settings
  netring: {
    key_prefix: "zensight/netring",
    sensor_id: "auto",

    // Live capture interfaces (needs CAP_NET_RAW). Leave empty and set `pcap`
    // below to replay an offline capture instead (no privileges required).
    interfaces: ["eth0"],
    // pcap: "/path/to/capture.pcap",

    collect: {
      bandwidth: true,   // per-application bytes/sec
      flows: true,       // flow lifecycle aggregates
      tcp_resets: true,  // TCP reset + connection-refused counters
    },
    bandwidth_period_secs: 5,

    // Pillar A — network anomaly detectors.
    anomalies: {
      port_scan: true,   // TRW port-scan detection -> alerts
    },

    // Threat-intel detection (netring 0.27). Hits become alerts on @/alerts via
    // the same path as the detectors above.
    threat: {
      // Passive flow-risk scoring: obsolete TLS, cleartext HTTP credentials.
      flow_risk: true,
      // Indicator-of-compromise matching (bad IPs / domains / JA3 / JA4).
      ioc: {
        ips: [],          // e.g. ["203.0.113.6"] — matched against flow src/dst
        domains: [],      // e.g. ["evil.example"] — DNS qname / TLS SNI / HTTP Host
        ja4: [],          // bad JA4 client fingerprints
        ja3: [],          // bad JA3 client fingerprints
        files: [],        // newline IOC feeds (IP or domain per line, # comments)
      },
      // Sigma rule evaluation (build with `--features sigma`).
      sigma: { enabled: false, dir: null },
    },

    // Capture-overload detection (netring 0.27). Watches the windowed capture
    // drop-rate and raises/clears a `capture-overload` SensorHealth alert on the
    // debounced Normal<->Emergency transition. Needs `collect.capture_stats`.
    overload: {
      enabled: true,
      enter_drop_rate: 0.05,    // enter Emergency at 5% windowed drop rate
      recover_drop_rate: 0.01,  // recover below 1% ...
      recover_windows: 3,       // ... sustained for 3 calm windows (hysteresis)
    },
  },

  logging: { level: "info" },
}
